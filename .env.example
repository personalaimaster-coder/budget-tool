# ----- Supabase (server-side only) -----
# Project URL: dashboard "Connect" button, or Settings > API ("Data API").
SUPABASE_URL=https://erilwcuvvznlszkoijfk.supabase.co
# Secret key (KEEP SECRET — full DB access, bypasses RLS). Never expose to the client.
# Settings > API Keys > "API Keys" tab -> create/copy an `sb_secret_...` key.
# (The legacy `service_role` JWT from the "Legacy API Keys" tab also works.)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key_here

# ----- Google Gemini -----
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gcp_api_key_here

# ----- App passcode (shared by the family) -----
# Anyone with this code can open the app.
APP_PASSCODE=1234
